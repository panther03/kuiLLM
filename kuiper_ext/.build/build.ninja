ninja_required_version = 1.3
cxx = c++
nvcc = /usr/local/cuda/bin/nvcc

cflags = -DTORCH_EXTENSION_NAME=kuiper_ext_native -DTORCH_API_INCLUDE_EXTENSION_H -I/home/julien/work/kuiper/include -I/home/julien/work/kuiper/dist -isystem /home/julien/work/kuiLLM/.venv/lib/python3.12/site-packages/torch/include -isystem /home/julien/work/kuiLLM/.venv/lib/python3.12/site-packages/torch/include/torch/csrc/api/include -isystem /usr/local/cuda/include -isystem /usr/include/python3.12 -fPIC -std=c++20 -O3 -std=c++17
post_cflags = 
cuda_cflags = -DTORCH_EXTENSION_NAME=kuiper_ext_native -DTORCH_API_INCLUDE_EXTENSION_H -I/home/julien/work/kuiper/include -I/home/julien/work/kuiper/dist -isystem /home/julien/work/kuiLLM/.venv/lib/python3.12/site-packages/torch/include -isystem /home/julien/work/kuiLLM/.venv/lib/python3.12/site-packages/torch/include/torch/csrc/api/include -isystem /usr/local/cuda/include -isystem /usr/include/python3.12 -D__CUDA_NO_HALF_OPERATORS__ -D__CUDA_NO_HALF_CONVERSIONS__ -D__CUDA_NO_BFLOAT16_CONVERSIONS__ -D__CUDA_NO_HALF2_OPERATORS__ --expt-relaxed-constexpr --compiler-options '-fPIC' -O3 --use_fast_math -Xcompiler -fPIC --expt-relaxed-constexpr -std=c++17 -U__CUDA_NO_HALF_OPERATORS__ -U__CUDA_NO_HALF_CONVERSIONS__ -U__CUDA_NO_HALF2_OPERATORS__ -U__CUDA_NO_BFLOAT16_CONVERSIONS__ -gencode=arch=compute_120,code=sm_120
cuda_post_cflags = 
cuda_dlink_post_cflags = 
sycl_dlink_post_cflags = 
ldflags = -shared -L/home/julien/work/kuiLLM/.venv/lib/python3.12/site-packages/torch/lib -lc10 -lc10_cuda -ltorch_cpu -ltorch_cuda -ltorch -ltorch_python -L/usr/local/cuda/lib64 -lcudart

rule compile
  command = $cxx -MMD -MF $out.d $cflags -c $in -o $out $post_cflags
  depfile = $out.d
  deps = gcc

rule cuda_compile
  depfile = $out.d
  deps = gcc
  command = $nvcc -MD -MF $out.d $cuda_cflags -c $in -o $out $cuda_post_cflags





rule link
  command = $cxx $in $ldflags -o $out

build ops.cuda.o: cuda_compile /home/julien/work/kuiLLM/kuiper_ext/csrc/ops.cu
build Klas_GEMM_BlockTiling1D.cuda.o: cuda_compile /home/julien/work/kuiper/dist/Klas_GEMM_BlockTiling1D.cu
build Klas_GEMM_SHMem.cuda.o: cuda_compile /home/julien/work/kuiper/dist/Klas_GEMM_SHMem.cu
build Klas_GEMM_TensorCore.cuda.o: cuda_compile /home/julien/work/kuiper/dist/Klas_GEMM_TensorCore.cu
build Klas_GEMM_TensorCore2D.cuda.o: cuda_compile /home/julien/work/kuiper/dist/Klas_GEMM_TensorCore2D.cu
build Klas_GEMM_Batched.cuda.o: cuda_compile /home/julien/work/kuiper/dist/Klas_GEMM_Batched.cu
build Klas_Softmax.cuda.o: cuda_compile /home/julien/work/kuiper/dist/Klas_Softmax.cu
build Klas_LogSoftmax.cuda.o: cuda_compile /home/julien/work/kuiper/dist/Klas_LogSoftmax.cu
build Klas_HReduce.cuda.o: cuda_compile /home/julien/work/kuiper/dist/Klas_HReduce.cu
build Klas_RowScale.cuda.o: cuda_compile /home/julien/work/kuiper/dist/Klas_RowScale.cu





build kuiper_ext_native.so: link ops.cuda.o Klas_GEMM_BlockTiling1D.cuda.o Klas_GEMM_SHMem.cuda.o Klas_GEMM_TensorCore.cuda.o Klas_GEMM_TensorCore2D.cuda.o Klas_GEMM_Batched.cuda.o Klas_Softmax.cuda.o Klas_LogSoftmax.cuda.o Klas_HReduce.cuda.o Klas_RowScale.cuda.o

default kuiper_ext_native.so
