# ── Byte-compiled / build artifacts ───────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.o
*.obj
*.cubin
*.fatbin
*.ptx
build/
dist/
*.egg-info/
.eggs/

# ── Virtual environments ──────────────────────────────────────────────────────
.venv/
venv/
env/
.env

# ── Editor / OS ───────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
.DS_Store

# ── JIT'd CUDA extension cache (torch.utils.cpp_extension) ────────────────────
# Built into ~/.cache/torch_extensions by default; only matters if someone
# overrides TORCH_EXTENSIONS_DIR into the repo.
torch_extensions/
kuiper_ext/.build/

# ── HuggingFace download cache (if user redirects HF_HOME here) ───────────────
.cache/
hf_cache/

# ── Profiler / model outputs ──────────────────────────────────────────────────
# These are large and regenerated by profile_ops.py / visualize_modules.py —
# keep them out of git.
trace.json
*.trace.json
kernels.png
call_tree.png
call_tree.txt
op_graph.png
module_graph.png

# ── Local notes / scratch ─────────────────────────────────────────────────────
scratch/
notes.local.md
